#!/usr/bin/env bash

set -euo pipefail

# Project root directory (defaults to git root or current directory)
export PROJECT_ROOT="${PROJECT_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"

# ------------------------------------------------------------
# Confirm poetry is installed
# ------------------------------------------------------------

if ! command -v poetry &>/dev/null; then
	echo "⚠️  Poetry is not installed. Please install Poetry to manage dependencies."
	echo "    Visit: https://python-poetry.org/docs/#installation"
	return 1
fi

# ------------------------------------------------------------
# Poetry Configuration
# ------------------------------------------------------------

# Ensure Poetry creates virtual environments in the project directory
export POETRY_VIRTUALENVS_IN_PROJECT=true
export POETRY_VIRTUALENVS_CREATE=true

# Disable Poetry's own virtual environment activation prompts
export POETRY_VIRTUALENVS_OPTIONS_NO_PIP=false
export POETRY_VIRTUALENVS_OPTIONS_NO_SETUPTOOLS=false

# ------------------------------------------------------------
# Poetry Virtual Environment Setup
# ------------------------------------------------------------

# Get the virtual environment path from Poetry
VENV_PATH="$(poetry env info --path 2>/dev/null || echo "${PROJECT_ROOT}/.venv")"

# Create and install if venv doesn't exist
if [[ ! -d ${VENV_PATH} ]]; then
	echo "📦 Creating Poetry virtual environment..."
	poetry install
	VENV_PATH="$(poetry env info --path)"
fi

# Auto-install/sync dependencies if lock file is newer than venv
if [[ -f poetry.lock && -d ${VENV_PATH} ]]; then
	if [[ poetry.lock -nt ${VENV_PATH} ]]; then
		echo "📦 poetry.lock updated, syncing dependencies..."
		poetry install --sync
	fi
fi

# Activate the virtual environment using direnv
if [[ -d ${VENV_PATH} ]]; then
	source_env "${VENV_PATH}/bin/activate"
	export VIRTUAL_ENV="${VENV_PATH}"
	PATH_add "${VENV_PATH}/bin"
fi

# ------------------------------------------------------------
# Environment variable setup
# ------------------------------------------------------------

if [[ ! -f .env ]]; then
	if [[ -f .env.example ]]; then
		echo "📝 Creating .env from .env.example..."
		cp .env.example .env
	fi
fi

if [[ ! -f terraform/terraform.tfvars ]]; then
	if [[ -f terraform/terraform.tfvars.example ]]; then
		echo "📝 Creating terraform.tfvars from example..."
		cp terraform/terraform.tfvars.example terraform/terraform.tfvars
	fi
fi

# Load .env file if it exists
dotenv_if_exists .env
