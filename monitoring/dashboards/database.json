{
  "title": "Database Performance",
  "tags": ["database", "postgres"],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Database Status",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "pg_up{job=\"postgres-exporter\"}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Active Connections",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "pg_stat_activity_count{job=\"postgres-exporter\",state=\"active\"}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 50,
                "color": "yellow"
              },
              {
                "value": 100,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Database Size",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "pg_database_size_bytes{job=\"postgres-exporter\"}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Total Connections",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count{job=\"postgres-exporter\"})",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 80,
                "color": "yellow"
              },
              {
                "value": 100,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Connections by State",
      "type": "graph",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "pg_stat_activity_count{job=\"postgres-exporter\"}",
          "legendFormat": "{{state}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "xaxis": {
        "show": true,
        "mode": "time"
      },
      "yaxes": [
        {
          "show": true,
          "format": "short",
          "label": "Connections"
        },
        {
          "show": true,
          "format": "short"
        }
      ]
    },
    {
      "id": 6,
      "title": "Transaction Rate",
      "type": "graph",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "Commits - {{datname}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "Rollbacks - {{datname}}",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "xaxis": {
        "show": true,
        "mode": "time"
      },
      "yaxes": [
        {
          "show": true,
          "format": "short",
          "label": "Transactions/sec"
        },
        {
          "show": true,
          "format": "short"
        }
      ]
    },
    {
      "id": 7,
      "title": "Rows Fetched vs Returned",
      "type": "graph",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_fetched{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "Fetched - {{datname}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        },
        {
          "expr": "rate(pg_stat_database_tup_returned{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "Returned - {{datname}}",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "xaxis": {
        "show": true,
        "mode": "time"
      },
      "yaxes": [
        {
          "show": true,
          "format": "short",
          "label": "Rows/sec"
        },
        {
          "show": true,
          "format": "short"
        }
      ]
    },
    {
      "id": 8,
      "title": "Database Operations",
      "type": "graph",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_inserted{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "Inserts - {{datname}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        },
        {
          "expr": "rate(pg_stat_database_tup_updated{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "Updates - {{datname}}",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        },
        {
          "expr": "rate(pg_stat_database_tup_deleted{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "Deletes - {{datname}}",
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "xaxis": {
        "show": true,
        "mode": "time"
      },
      "yaxes": [
        {
          "show": true,
          "format": "short",
          "label": "Operations/sec"
        },
        {
          "show": true,
          "format": "short"
        }
      ]
    }
  ]
}
