{
  "title": "Infrastructure & Resource Usage",
  "tags": ["infrastructure", "process", "resources"],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 99,
      "title": "⚠️ Kubernetes Metrics Unavailable",
      "type": "text",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "options": {
        "mode": "markdown",
        "content": "**kube-state-metrics** not installed. Install with:\n```bash\nkubectl apply -f https://github.com/kubernetes/kube-state-metrics/releases/latest/download/kube-state-metrics.yaml\n```\nShowing **process-level metrics** from API pods below:"
      }
    },
    {
      "id": 1,
      "title": "Process CPU Usage by Pod",
      "type": "graph",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"api\"}[1m])",
          "legendFormat": "{{pod}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "xaxis": {
        "show": true,
        "mode": "time"
      },
      "yaxes": [
        {
          "show": true,
          "format": "percentunit",
          "label": "CPU"
        },
        {
          "show": true,
          "format": "short"
        }
      ]
    },
    {
      "id": 2,
      "title": "Process Memory Usage by Pod",
      "type": "graph",
      "gridPos": {
        "x": 12,
        "y": 3,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"api\"} / 1024 / 1024",
          "legendFormat": "{{pod}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "xaxis": {
        "show": true,
        "mode": "time"
      },
      "yaxes": [
        {
          "show": true,
          "format": "mbytes",
          "label": "Memory (MB)"
        },
        {
          "show": true,
          "format": "short"
        }
      ]
    },
    {
      "id": 3,
      "title": "Open File Descriptors",
      "type": "graph",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "process_open_fds{job=\"api\"}",
          "legendFormat": "{{pod}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "xaxis": {
        "show": true,
        "mode": "time"
      },
      "yaxes": [
        {
          "show": true,
          "format": "short",
          "label": "FDs"
        },
        {
          "show": true,
          "format": "short"
        }
      ]
    },
    {
      "id": 4,
      "title": "Network Traffic (RX)",
      "type": "graph",
      "gridPos": {
        "x": 12,
        "y": 11,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(process_network_receive_bytes_total{job=\"api\"}[1m])",
          "legendFormat": "{{pod}} RX",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "xaxis": {
        "show": true,
        "mode": "time"
      },
      "yaxes": [
        {
          "show": true,
          "format": "Bps",
          "label": "Bytes/sec"
        },
        {
          "show": true,
          "format": "short"
        }
      ]
    },
    {
