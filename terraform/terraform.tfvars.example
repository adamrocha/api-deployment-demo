# Example Terraform variables
# Copy this file to terraform.tfvars and customize
# 
# ⚠️ SECURITY BEST PRACTICES:
# 1. NEVER commit terraform.tfvars to version control (already in .gitignore)
# 2. Use strong, randomly generated secrets (see recommendations below)
# 3. Rotate secrets regularly (recommended: every 90 days)
# 4. Use different secrets for each environment
# 5. For production, consider external secret management:
#    - HashiCorp Vault
#    - AWS Secrets Manager / Parameter Store
#    - Azure Key Vault
#    - Google Secret Manager
#    - Kubernetes External Secrets Operator
# 6. Enable encryption at rest for Kubernetes secrets in production
# 7. Use RBAC to restrict access to secrets

project_name = "api-deployment-demo"
environment  = "staging"  # or "production"

# Cluster configuration
cluster_name    = "api-demo-cluster"
kubeconfig_path = "~/.kube/config"

# ====================================================================
# SECURITY CREDENTIALS
# ====================================================================
# ⚠️ CRITICAL: Replace these with secure values!
# 
# Generate secure passwords using:
#   openssl rand -base64 32
#   python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
#   pwgen -s 32 1
# 
# Requirements:
#   - Minimum 32 characters
#   - Mix of uppercase, lowercase, numbers, special chars
#   - Never use dictionary words or common patterns
#   - Different values for staging and production

db_password = "CHANGE_ME_USE_STRONG_RANDOM_PASSWORD_HERE"
secret_key  = "CHANGE_ME_USE_STRONG_RANDOM_SECRET_KEY_HERE"

# Staging ports
staging_ports = {
  http  = 30080
  https = 30443
  api   = 30800
  db    = 35432
}

# Production configuration
replicas          = 2
enable_monitoring = true

# Docker images
docker_images = {
  api = {
    name    = "api-deployment-demo-api"
    context = "../api"
    tag     = "latest"
  }
  nginx = {
    name    = "api-deployment-demo-nginx"
    context = "../nginx"
    tag     = "latest"
  }
}
